{
  "name": "confetti-design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Confetti — personal portfolio design system. Multi-skin, multi-mode token architecture.",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "tokens": "npm run audit:tokens && node style-dictionary/build.js",
    "audit:tokens": "node style-dictionary/audit-layers.js",
    "storybook": "npm run tokens && storybook dev -p 6006",
    "build-storybook": "npm run tokens && storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/preview-api": "^8.6.18",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "chromatic": "^18.0.1",
    "postcss": "^8.4.49",
    "storybook": "^8.6.14",
    "style-dictionary": "^4.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
