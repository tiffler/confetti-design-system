{
  "font": {
    "family": {
      "$comment": "Two typefaces, Fredoka and JetBrains Mono. Everything after the first name in each stack is a fallback for before the webfont loads — not a third face in the system.",
      "fredoka": { "value": "Fredoka, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif" },
      "mono": { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" }
    },
    "size": {
      "$comment": "Named by px so the ramp is self-documenting. Every step lands on the 4px grid the spacing scale uses, so type and space stay commensurate.",
      "12": { "value": "12px" },
      "14": { "value": "14px" },
      "16": { "value": "16px" },
      "20": { "value": "20px" },
      "24": { "value": "24px" },
      "32": { "value": "32px" },
      "40": { "value": "40px" },
      "48": { "value": "48px" },
      "hero": { "value": "clamp(36px, 13cqw, 104px)", "comment": "container-query driven headline, above the fixed ramp" }
    },
    "weight": {
      "medium": { "value": "500" },
      "semibold": { "value": "600" },
      "bold": { "value": "700" }
    },
    "tracking": {
      "tight": { "value": "-0.03em" },
      "normal": { "value": "0" },
      "wide": { "value": "0.16em" }
    },
    "leading": {
      "none": { "value": "1" },
      "snug": { "value": "1.3" },
      "normal": { "value": "1.5" }
    }
  }
}
