{
  "$comment": "Confetti — light mode. Colors extracted from the live Claude Design comps and homepage hero code. These are final; do not re-derive.",
  "color": {
    "surface": {
      "page": { "value": "{color.cream.300.value}" },
      "raised": { "value": "{color.cream.100.value}" },
      "panel": { "value": "{color.cream.200.value}" },
      "card": { "value": "{color.base.white.value}" }
    },
    "text": {
      "primary": { "value": "{color.ink.600.value}" },
      "muted": { "value": "{color.ink.300.value}" },
      "inverse": { "value": "{color.base.white.value}" },
      "accent": { "value": "{color.red.500.value}" }
    },
    "border": {
      "default": { "value": "{color.ink.600.value}" },
      "subtle": { "value": "{color.ink.a12.value}" },
      "none": { "value": "{color.base.transparent.value}", "comment": "an explicit absence — variants that keep the border box without drawing an edge" }
    },
    "action": {
      "primary": {
        "bg": { "value": "{color.red.500.value}" },
        "fg": { "value": "{color.base.white.value}" }
      },
      "secondary": {
        "bg": { "value": "{color.cream.300.value}" },
        "fg": { "value": "{color.ink.600.value}" }
      },
      "ghost": {
        "bg": { "value": "{color.base.transparent.value}" },
        "fg": { "value": "{color.ink.600.value}" },
        "fg-hover": { "value": "{color.red.500.value}" }
      }
    },
    "accent": {
      "purple": {
        "subtle": { "value": "{color.purple.100.value}" },
        "bold": { "value": "{color.purple.400.value}" }
      },
      "teal": {
        "subtle": { "value": "{color.teal.100.value}" },
        "bold": { "value": "{color.teal.400.value}" }
      },
      "orange": {
        "subtle": { "value": "{color.orange.100.value}" },
        "bold": { "value": "{color.orange.400.value}" }
      },
      "pink": {
        "subtle": { "value": "{color.pink.100.value}" },
        "bold": { "value": "{color.pink.400.value}" }
      },
      "on-bold": { "value": "{color.ink.600.value}" },
      "on-subtle": { "value": "{color.ink.600.value}" }
    }
  },
  "shadow": {
    "lift": { "value": "{shadow.hard-ink.value}" }
  },
  "font": {
    "family": {
      "display": { "value": "{font.family.fredoka.value}" },
      "body": { "value": "{font.family.fredoka.value}" },
      "label": { "value": "{font.family.mono.value}" }
    },
    "size": {
      "$comment": "Heading ramp is a 1.25 modular scale rounded to the 4px grid: 48 / 40 / 32 / 24 / 20 / 16.",
      "display": { "value": "{font.size.hero.value}", "comment": "hero only — fluid, sits above h1" },
      "h1": { "value": "{font.size.48.value}" },
      "h2": { "value": "{font.size.40.value}" },
      "h3": { "value": "{font.size.32.value}" },
      "h4": { "value": "{font.size.24.value}" },
      "h5": { "value": "{font.size.20.value}" },
      "h6": { "value": "{font.size.16.value}", "comment": "meets body size — weight and family carry the distinction" },
      "body": { "value": "{font.size.16.value}", "comment": "16px — body primary" },
      "body-secondary": { "value": "{font.size.14.value}", "comment": "14px — captions, meta, dense UI" },
      "label": { "value": "{font.size.12.value}", "comment": "12px — mono eyebrows, uppercase" }
    },
    "weight": {
      "display": { "value": "{font.weight.semibold.value}" },
      "body": { "value": "{font.weight.medium.value}" },
      "control": { "value": "{font.weight.medium.value}", "comment": "500 — button and control labels" },
      "label": { "value": "{font.weight.bold.value}" }
    },
    "tracking": {
      "display": { "value": "{font.tracking.tight.value}" },
      "label": { "value": "{font.tracking.wide.value}" }
    },
    "leading": {
      "display": { "value": "{font.leading.none.value}" },
      "heading": { "value": "{font.leading.snug.value}" },
      "body": { "value": "{font.leading.normal.value}" }
    }
  },
  "radius": {
    "control": { "value": "{radius.full.value}" },
    "container": { "value": "{radius.md.value}" },
    "chip": { "value": "{radius.xs.value}" },
    "avatar": { "value": "{radius.circle.value}" }
  },
  "border": {
    "width": {
      "default": { "value": "{border.width.sticker.value}" }
    }
  },
  "size": {
    "control": {
      "value": "{space.12.value}",
      "comment": "48px — height of a tappable control. Padding sets the horizontal rhythm; this sets the vertical."
    }
  },
  "space": {
    "$comment": "Four steps, smallest to largest: 4, 8, 16, 24.",
    "inset-xs": { "value": "{space.1.value}", "comment": "4px — tightest inset, chips and dots" },
    "inline": { "value": "{space.2.value}", "comment": "8px — gap between inline siblings" },
    "inset-tight": { "value": "{space.2.value}", "comment": "8px — compact control padding" },
    "stack": { "value": "{space.4.value}", "comment": "16px — vertical rhythm inside a container" },
    "inset": { "value": "{space.6.value}", "comment": "24px — container padding" }
  },
  "motion": {
    "$comment": "Leaf names differ from the primitives they alias — motion.transform.lift vs motion.lift — because a semantic role sharing a primitive's full path would collide in the flat CSS namespace.",
    "transform": {
      "lift": { "value": "{motion.lift.value}", "comment": "how far an interactive surface rises on hover" },
      "rest": { "value": "{motion.rest.value}" }
    },
    "tilt": {
      "max": { "value": "{motion.tilt.subtle.value}", "comment": "outer bound of the hand-placed sticker angle" }
    },
    "duration": {
      "interaction": { "value": "{motion.duration.base.value}", "comment": "hover and focus transitions" }
    },
    "easing": {
      "interaction": { "value": "{motion.easing.standard.value}" }
    }
  }
}
