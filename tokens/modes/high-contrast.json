{
  "$comment": "MODE = high-contrast. Pure black-on-white neutrals. Borders are SOLID black (no low-alpha). Muted text collapses to black (no greys). The decorative subtle accent tints become SOLID white — the hue is dropped in favour of a visible border + the text label, so nothing relies on colour alone (see Badge/Card component rules). Focus ring is heavy (4px). Emitted under [data-mode='high-contrast'].",
  "color": {
    "surface": {
      "page": { "value": "{color.base.white}" },
      "raised": { "value": "{color.base.white}" },
      "panel": { "value": "{color.base.white}" },
      "card": { "value": "{color.base.white}" }
    },
    "text": {
      "primary": { "value": "{color.base.black}" },
      "muted": { "value": "{color.base.black}", "comment": "no muted greys in high-contrast — muted collapses to full black" },
      "inverse": { "value": "{color.base.white}" }
    },
    "border": {
      "default": { "value": "{color.base.black}" },
      "subtle": { "value": "{color.base.black}", "comment": "subtle borders become solid black — no low-alpha edges" },
      "none": { "value": "{color.base.transparent}" }
    },
    "action": {
      "secondary": {
        "bg": { "value": "{color.base.white}" },
        "fg": { "value": "{color.base.black}" }
      },
      "ghost": { "bg": { "value": "{color.base.transparent}" }, "fg": { "value": "{color.base.black}" } }
    },
    "accent": {
      "purple": { "subtle": { "value": "{color.base.white}" } },
      "teal": { "subtle": { "value": "{color.base.white}" } },
      "orange": { "subtle": { "value": "{color.base.white}" } },
      "pink": { "subtle": { "value": "{color.base.white}" } },
      "on-bold": { "value": "{color.base.black}", "comment": "black on any bold hue — components add a border so hue is never the only signal" },
      "on-subtle": { "value": "{color.base.black}" }
    }
  },
  "shadow": { "lift": { "value": "3px 3px 0px 0px {color.base.black}" } },
  "focus": {
    "ring": {
      "width": { "value": "{border.width.heavy}", "comment": "4px — thicker ring for high-contrast" },
      "color": { "value": "{color.base.black}" },
      "offset": { "value": "{border.width.sticker}", "comment": "2px" }
    }
  }
}
