{
  "$comment": "Component tokens reference semantic tokens only — never primitives, never raw values.",
  "button": {
    "radius": { "value": "{radius.control}" },
    "border-width": { "value": "{border.width.default}" },
    "font-family": { "value": "{font.family.label}" },
    "font-size": { "value": "{font.size.body-secondary}" },
    "font-weight": { "value": "{font.weight.control}" },
    "$comment": "Mono uppercase always carries the wide label tracking — without it the caps set too tight to read.",
    "tracking": { "value": "{font.tracking.label}" },
    "min-height": { "value": "{size.control}" },
    "padding-x": { "value": "{space.inset}" },
    "padding-y": { "value": "{space.inset-tight}" },
    "gap": { "value": "{space.inline}" },
    "shadow-hover": { "value": "{shadow.button-lift}" },
    "transform-hover": { "value": "{motion.button-lift}" },
    "hover-brightness": { "value": "{effect.button-hover-brightness}" },
    "transition-duration": { "value": "{motion.duration.interaction}" },
    "transition-easing": { "value": "{motion.easing.interaction}" },
    "primary": {
      "bg": { "value": "{color.action.primary.bg}" },
      "fg": { "value": "{color.action.primary.fg}" },
      "$comment": "Ink border is a global sticker rule — primary and secondary differ by fill, not by outline. The hard shadow extrudes from this edge.",
      "border": { "value": "{color.border.default}" }
    },
    "secondary": {
      "bg": { "value": "{color.action.secondary.bg}" },
      "fg": { "value": "{color.action.secondary.fg}" },
      "border": { "value": "{color.border.default}" }
    },
    "ghost": {
      "bg": { "value": "{color.action.ghost.bg}" },
      "fg": { "value": "{color.action.ghost.fg}" },
      "fg-hover": { "value": "{color.action.ghost.fg-hover}" },
      "border": { "value": "{color.border.none}" }
    }
  }
}
