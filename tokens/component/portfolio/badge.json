{
  "badge": {
    "radius": { "value": "{radius.control}" },
    "border-width": { "value": "{border.width.default}" },
    "border-color": { "value": "{color.border.default}" },
    "font-family": { "value": "{font.family.label}" },
    "font-size": { "value": "{font.size.label}" },
    "font-weight": { "value": "{font.weight.label}" },
    "tracking": { "value": "{font.tracking.label}" },
    "padding-x": { "value": "{space.inset-tight}" },
    "padding-y": { "value": "{space.inset-xs}" },
    "fg": { "value": "{color.accent.on-bold}" },
    "fg-subtle": { "value": "{color.accent.on-subtle}" },
    "bg": {
      "purple": { "value": "{color.accent.purple.bold}" },
      "teal": { "value": "{color.accent.teal.bold}" },
      "orange": { "value": "{color.accent.orange.bold}" },
      "pink": { "value": "{color.accent.pink.bold}" }
    },
    "bg-subtle": {
      "purple": { "value": "{color.accent.purple.subtle}" },
      "teal": { "value": "{color.accent.teal.subtle}" },
      "orange": { "value": "{color.accent.orange.subtle}" },
      "pink": { "value": "{color.accent.pink.subtle}" }
    }
  }
}
